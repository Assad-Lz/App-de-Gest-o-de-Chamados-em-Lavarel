APP_NAME="Gestão de Chamados"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------------------------------
# Banco de Dados – Supabase (PostgreSQL)
# Substitua pelos dados do seu projeto Supabase:
# Acesse: https://app.supabase.com → Settings → Database
# -------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db.XXXXXXXXXXXXXXXX.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=SUA_SENHA_SUPABASE_AQUI

# -------------------------------------------------------
# Cache e Sessão
# -------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# -------------------------------------------------------
# Frontend URL (para CORS)
# -------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -------------------------------------------------------
# Rate Limiting
# -------------------------------------------------------
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=1

# -------------------------------------------------------
# Honeypot (logging de atividade suspeita)
# -------------------------------------------------------
HONEYPOT_LOG_CHANNEL=honeypot
HONEYPOT_BLOCK_DURATION=3600
